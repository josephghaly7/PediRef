    {
      "name": "Neonatal Resuscitation",
      "subCategories": [
        {
          "name": "all",
          "items": [
            {
              "name": "Notes:",
              "notes": [
                "for use with known patient weight.  If weight is not known, refer to GESTATIONAL AGE ESTIMATES for weight and medication dosing"
              ]
            },
            {
              "name": "1.) Term Gestation? Good Tone? Breathing / Crying?",
              "steps": [
                {
                  "algostep": "Yes?",
                  "title": true
                },
                {
                  "algostep": "\u25cf Warm / maintain temperature, dry with towels, position airway, place infant on mother's chest.  Continue to assess",
                  "title": false
                },
                {
                  "algostep": "NO?",
                  "title": true
                },
                {
                  "algostep": "\u25cf  if infant is NOT term, does NOT have good tone, NOT breathing or crying:",
                  "title": false
                },
                {
                  "algostep": "Warming:",
                  "title": true
                },
                {
                  "algostep": "\u25cf Initial priority is to warm infant, position airway, and stimulate",
                  "title": false
                },
                {
                  "algostep": "\u25cf Target temperature 36.5-37.5  deg C axillary\nUse infant warmer (25 deg C),\nthermal mattress, or heated blankets",
                  "title": false
                },
                {
                  "algostep": "Position Airway:",
                  "title": true
                },
                {
                  "algostep": "\u25cf roll under shoulders - head in neutral / slightly extended position (align auditory meatus with suprasternal notch)",
                  "title": false
                },
                {
                  "algostep": "\u25cf use jaw thrust or place oral / nasal airway to minimize obstruction",
                  "title": false
                },
                {
                  "algostep": "\u25cf suctioning NOT recommended unless complete airway obstruction",
                  "title": false
                },
                {
                  "algostep": "Stimulation:",
                  "title": true
                },
                {
                  "algostep": "\u25cf Rub infant's back, flick soles of feet.  Towel drying in infant > 32 weeks provides additional stimulation",
                  "title": false
                }
              ]
            },
            {
              "name": "2.) Cardiorespiratory Assessment",
              "steps": [
                {
                  "algostep": "Labored breathing / persistent cyanosis, but HR > 100:",
                  "title": true
                },
                {
                  "algostep": "\u25cf Reposition / clear airway,\nJaw thrust\n\u2022Place SpO2 probe to monitor pre-ductal oxygen saturation (Right hand / wrist)",
                  "title": false
                },
                {
                  "algostep": "\u25cf Apply supplemental O2 as needed, consider positive pressure ventilation",
                  "title": false
                },
                {
                  "algostep": "\u25cf Continue to monitor HR",
                  "title": false
                },
                {
                  "algostep": "Apneic / Gasping; or HR < 100",
                  "title": true
                },
                {
                  "algostep": "\u25cf Provide positive pressure ventilation in addition to above steps",
                  "title": false
                },
                {
                  "algostep": "\u25cf Target 40 breaths/minute and effective ventilation",
                  "title": false
                },
                {
                  "algostep": "\u25cf When possible, provide PPV through T-piece resuscitator or flow-inflating bag",
                  "title": false
                },
                {
                  "algostep": "\u2022b/CPAP/b - PEEP 5-8; \nPPV - PIP 20, or until chest rise",
                  "title": false
                },
                {
                  "algostep": "\u25cf If not improved after 30 seconds, consider:\nmask adjustment, reposition airway, suctioning, opening mouth, increase PEEP to 6-8 and PPV> 20, advanced airway including supraglottic",
                  "title": false
                }
              ]
            },
            {
              "name": "3.) HR < 60?",
              "steps": [
                {
                  "algostep": "Initial Steps",
                  "title": true
                },
                {
                  "algostep": "\u25cf Intubate / Supraglottic airway\n(Ventilation is priority!)",
                  "title": false
                },
                {
                  "algostep": "\u25cf Chest compressions\ncoordinate with ventilations",
                  "title": false
                },
                {
                  "algostep": "\u25cf 3:1 (90 compressions : 30 ventilations / minute)",
                  "title": false
                },
                {
                  "algostep": "\u25cf recheck pulse / HR every 60 seconds",
                  "title": false
                },
                {
                  "algostep": "Vascular Access:",
                  "title": true
                },
                {
                  "algostep": "\u25cf umbilcal vein catheter preferred \n\u25cf Intraosseous access only for term infants > 3 kg.",
                  "title": false
                },
                {
                  "algostep": "Epinephrine 0.1 mg/mL (1:10,000) IV/IO",
                  "title": true
                },
                {
                  "range1": "0.01",
                  "range2": "0.03",
                  "unit": "mg",
                  "label": "",
                  "formula": "0.01-0.03 mg/kg",
                  "max": "",
                  "multipliers": [
                    "kg"
                  ],
                  "volumes": [
                    {
                      "value": "0.1",
                      "unit": "mL",
                      "formula": "0.1 mg/mL",
                      "multipliers": [
                        "dose"
                      ]
                    }
                  ],
                  "rangeUnit": "mg/kg",
                  "segments": [
                    "0.01",
                    "0.02",
                    "0.03"
                  ]
                },
                {
                  "algostep": "Epinephrine 0.1 mg/mL ETT",
                  "title": true
                },
                {
                  "range1": "0.05",
                  "range2": "0.1",
                  "unit": "mg",
                  "label": "",
                  "formula": "0.05-0.1 mg/kg",
                  "max": "",
                  "multipliers": [
                    "kg"
                  ],
                  "volumes": [
                    {
                      "value": "0.1",
                      "unit": "mL",
                      "formula": "0.1 mg/mL",
                      "multipliers": [
                        "dose"
                      ]
                    }
                  ]
                },
                {
                  "algostep": "\u25cf  Enter b/WEIGHT/b using scale icon above  OR\n\u25cf Use b/GESTATIONAL AGE ESTIMATES/b if weight not known ",
                  "title": false
                },
                {
                  "algostep": "Fluid and Glucose",
                  "title": true
                },
                {
                  "algostep": "\u25cf Consider fluid bolus NS 10 mL/kg",
                  "title": false
                },
                {
                  "range1": "10",
                  "range2": "",
                  "unit": "mL",
                  "label": "",
                  "formula": "10 mL/kg",
                  "max": "",
                  "multipliers": [
                    "kg"
                  ],
                  "volumes": []
                },
                {
                  "algostep": "\u25cf Check blood glucose, consider D10 bolus 2 mL/kg",
                  "title": false
                },
                {
                  "range1": "2",
                  "range2": "",
                  "unit": "mL",
                  "label": "",
                  "formula": "D10 2 mL/kg",
                  "max": "",
                  "multipliers": [
                    "kg"
                  ],
                  "volumes": []
                }
              ]
            },
            {
              "name": "4.) Resuscitation Goals: (STABLE)",
              "steps": [
                {
                  "algostep": "Sugar",
                  "title": true
                },
                {
                  "algostep": "\u25cf check blood glucose, treat hypoglycemia, consider D10 bolus ",
                  "title": false
                },
                {
                  "algostep": "Temperature",
                  "title": true
                },
                {
                  "algostep": "\u25cf 36.5-37.5 deg C",
                  "title": false
                },
                {
                  "algostep": "Airway",
                  "title": true
                },
                {
                  "algostep": "\u25cf positioning, appropriate equipment, supraglottic airway is as good / better than ETT",
                  "title": false
                },
                {
                  "algostep": "Breathing",
                  "title": true
                },
                {
                  "algostep": "\u25cf goal is SpO2 > 90% after 1o minutes.  \n\u25cf Assist ventilation when necessary, consider PPV or advanced airway",
                  "title": false
                },
                {
                  "algostep": "Labs:",
                  "title": true
                },
                {
                  "algostep": "\u25cf evaluate glucose, CO2 for appropriate ventilation, labs for evidence of infection",
                  "title": false
                },
                {
                  "algostep": "Emotional Support",
                  "title": true
                },
                {
                  "algostep": "\u25cf assign staff to provide emotional support for mother and family",
                  "title": false
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "name": "Gestational Age Estimates",
      "subCategories": [
        {
          "name": "all",
          "items": [
            {
              "name": "Disclaimer and Info",
              "notes": [
                "\u25cf Displayed content including weights and dosing are based on gestational age and estimated weight. ",
                "\u25cf  Confirmation of exact weight is recommended as early as possible.",
                "\u25cf Laryngoscope blade use size 0 for preterm infants, Size 1 for term infants",
                "\u25cf LMA size 1 (< 5 kg)",
                "\u25cf I-Gel size 1 (2-5 kg)",
                "\u25cf Epinephrine 0.1 mg/mL IV/IO (1:10,000), displayed dosing is 0.02 mg/kg, 0.2 mL/kg (Recommended dose is 0.01-0.03 mg/kg, or 0.1-0.3 mL/kg)",
                "\u25cf Epinephrine 0.1 mg/ml ETT (1:10,000), displayed dosing is 0.3-1 mL/kg"
              ]
            },
            {
              "name": "Gestational Age /  Weight",
              "steps": [
                {
