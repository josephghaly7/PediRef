                  "title": true
                },
                {
                  "algostep": "\u25cf Est Weight: 500-600 g\n\u25cf ETT size: 2.5\n\u25cf Insertion Depth: 5.5 cm\n\u25cf LMA size 1\n\u25cf Epinephrine IV =  0.01 mg, 0.1 mL\n\u25cf Epinephrine ETT = 0.15-0.5 mL",
                  "title": false
                },
                {
                  "algostep": "25-26 weeks",
                  "title": true
                },
                {
                  "algostep": "\u25cf Est Weight: 700-800 g\n\u25cf ETT size: 2.5\n\u25cf Insertion Depth: 6.0 cm\n\u25cf LMA size 1\n\u25cf Epinephrine IV =  0.015 mg, 0.15 mL\n\u25cf Epinephrine ETT = 0.2-0.7 mL",
                  "title": false
                },
                {
                  "algostep": "27-29 weeks",
                  "title": true
                },
                {
                  "algostep": "\u25cf Est Weight: 900-1000 g\n\u25cf ETT size: 2.5-3.0\n\u25cf Insertion Depth: 6.0 cm\n\u25cf LMA size 1\n\u25cf Epinephrine IV =  0.02 mg, 0.2 mL\n\u25cf Epinephrine ETT = 0.3-1 mL",
                  "title": false
                },
                {
                  "algostep": "30-32 weeks",
                  "title": true
                },
                {
                  "algostep": "\u25cf Est Weight: 1100-1400 g\n\u25cf ETT size: 3.0\n\u25cf Insertion Depth: 7.0 cm\n\u25cf LMA size 1\n\u25cf Epinephrine IV =  0.025 mg, 0.25 mL\n\u25cf Epinephrine ETT = 0.35-1.2 mL",
                  "title": false
                },
                {
                  "algostep": "33-34 weeks",
                  "title": true
                },
                {
                  "algostep": "\u25cf Est Weight: 1500-1800 g\n\u25cf ETT size: 3.0\n\u25cf Insertion Depth: 7.5 cm\n\u25cf LMA size 1\n\u25cf Epinephrine IV =  0.03 mg, 0.3 mL\n\u25cf Epinephrine ETT = 0.45-1.5 mL",
                  "title": false
                },
                {
                  "algostep": "35-37 weeks",
                  "title": true
                },
                {
                  "algostep": "\u25cf Est Weight: 1900-2400 g\n\u25cf ETT size: 3.5\n\u25cf Insertion Depth: 8.0 cm\n\u25cf LMA size 1\n\u25cf I-Gel size 1\n\u25cf Epinephrine IV =  0.04 mg, 0.4 mL\n\u25cf Epinephrine ETT = 0.6-2 mL",
                  "title": false
                },
                {
                  "algostep": "38-40 weeks",
                  "title": true
                },
                {
                  "algostep": "\u25cf Est Weight: 2500-3100 g\n\u25cf ETT size: 3.5-4.0\n\u25cf Insertion Depth: 8.5 cm\n\u25cf Epinephrine IV =  0.05 mg, 0.5 mL\n\u25cf Epinephrine ETT = 0.8-3 mL",
                  "title": false
                },
                {
                  "algostep": "41-43 weeks",
                  "title": true
                },
                {
                  "algostep": "\u25cf Est Weight: 3200-4200 g\n\u25cf ETT size: 3.5-4.0\n\u25cf Insertion Depth: 9.0 cm\n\u25cf LMA size 1\n\u25cf I-Gel size 1\n\u25cf Epinephrine IV =  0.06-0.8 mg, 0.6-0.8 mL\n\u25cf Epinephrine ETT = 1-4 mL",
                  "title": false
                }
              ]
            }
          ]
        }
